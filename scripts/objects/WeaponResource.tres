[gd_resource type="Resource" format=3 uid="uid://canu3fekxtmj7"]

[sub_resource type="GDScript" id="GDScript_ibg4l"]
script/source = "class_name WeaponResource
extends Resource

enum DAMAGE_TYPES { STAB, SLASH, CRUSH, PURE}

@export_category(\"Appearance\")
@export var weaponModel: Mesh
#@export_enum(\"Damage Type\", \"DAMAGE_TYPES\")

@export_category(\"Damage Attributes\")
@export var damage: float  = 1
@export_subgroup(\"Range\", \"range\")
@export var range_y: float = 2.0
@export var range_x: float = 2.5
@export var range_z: float = 2.5
"

[resource]
script = SubResource("GDScript_ibg4l")
